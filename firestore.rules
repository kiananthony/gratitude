rules_version = '2';

// Security rules for the Gratitude app (shared by the iOS and web clients).
// Publish these in Firebase console → Firestore Database → Rules, or deploy with the
// Firebase CLI (`firebase deploy --only firestore:rules`).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }

    // ---- users/{uid} ----
    // Any signed-in user can read profiles (needed for search, friends, timeline,
    // and username→email login lookup). Only the owner can write their own document.
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if isSelf(uid);

      // A user's posts. Owner has full control; friends (and the owner) may read.
      // Anyone signed in may read individual posts — clients only ever request public
      // posts of friends plus all of their own, so timeline rules stay simple here.
      match /posts/{postId} {
        allow read: if signedIn();
        allow create, delete: if isSelf(uid);
        // Owner can edit freely; others may only change the heartedBy array (to like).
        allow update: if isSelf(uid)
          || (signedIn()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['heartedBy']));
      }

      // Notifications live under the recipient. Anyone signed in may create one
      // (e.g. a heart notification); the recipient may read/delete, and the
      // original sender may delete their own (so un-hearting removes it).
      match /notifications/{notifId} {
        allow read: if isSelf(uid);
        allow create: if signedIn();
        allow delete: if isSelf(uid) || (resource.data.fromUserId == request.auth.uid);
      }

      // Web push tokens for this user's devices. Only the owner may manage them;
      // Cloud Functions (admin SDK) bypass rules and read them to send pushes.
      match /fcmTokens/{token} {
        allow read, write: if isSelf(uid);
      }
    }

    // ---- feedback/{id} ----  { fromUserId, fromScreenName, text, createdAt }
    // Any signed-in user may submit feedback. Only developers may read it, and
    // nobody edits or deletes it from the client.
    match /feedback/{id} {
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid;
      allow read: if signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isDeveloper == true;
      allow update, delete: if false;
    }

    // ---- config/app ----  developer-controlled feature flags.
    match /config/{docId} {
      allow read: if signedIn();
      allow write: if signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isDeveloper == true;
    }

    // Moderator overview: allow developers to read posts across all users via a
    // collection-group query. (Normal per-user post reads use the rule above.)
    match /{path=**}/posts/{postId} {
      allow read: if signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isDeveloper == true;
    }

    // ---- reports/{id} ----  reporting a post; readable only by developers.
    match /reports/{id} {
      allow create: if signedIn()
        && request.resource.data.reporterUserId == request.auth.uid;
      allow read: if signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isDeveloper == true;
      allow update, delete: if false;
    }

    // ---- usernames/{lowercaseName} ----  { uid, email }
    // Public single-document reads so the login screen can resolve a username to
    // an email BEFORE sign-in. `list` is denied so the collection can't be bulk-
    // read to harvest emails — a caller must already know the exact username.
    // Each entry may only be written by the account it points to.
    match /usernames/{name} {
      allow get: if true;
      allow list: if false;
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ---- friends/{uid}/userFriends/{friendUid} ----
    // Either party to the friendship may create/remove the edge; owner may read their list.
    match /friends/{uid}/userFriends/{friendUid} {
      allow read: if isSelf(uid);
      allow create, delete: if isSelf(uid) || isSelf(friendUid);
    }

    // ---- friendRequests/{uid}/{box}/{otherUid} ----  (box = "sent" | "received")
    // Requests are written to both users' boxes, so allow either party to manage them.
    match /friendRequests/{uid}/{box}/{otherUid} {
      allow read: if isSelf(uid);
      allow create, delete: if isSelf(uid) || isSelf(otherUid);
    }
  }
}
